<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <!-- guarda los logs en un archivo que cambia cada dia automaticamente -->
        <RollingFile name="Archivo"
                     fileName="logs/primetech.log"
                     filePattern="logs/primetech-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-5p] %c{1} - %m%n"/>
            <TimeBasedTriggeringPolicy/>
        </RollingFile>

        <!-- tambien los muestro por consola mientras desarrollo -->
        <Console name="Consola" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} [%-5p] %c{1} - %m%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Archivo"/>
            <AppenderRef ref="Consola"/>
        </Root>
    </Loggers>

</Configuration>

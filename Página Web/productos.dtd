<!-- 
  Archivo: productos.dtd
  Empresa: PrimeTech Systems
  Descripción: DTD para validar el archivo productos.xml
-->

<!-- Elemento raíz del catálogo -->
<!ELEMENT catalogo (producto+)>
<!ATTLIST catalogo
  empresa CDATA #REQUIRED
  fecha   CDATA #REQUIRED
>

<!-- Cada producto tiene estos elementos obligatorios -->
<!ELEMENT producto (nombre, categoria, precio, disponibilidad, descripcion, especificaciones, imagen, garantia_anios)>
<!ATTLIST producto
  id CDATA #REQUIRED
>

<!-- Datos básicos del producto -->
<!ELEMENT nombre         (#PCDATA)>
<!ELEMENT categoria      (#PCDATA)>
<!ELEMENT disponibilidad (#PCDATA)>
<!ELEMENT descripcion    (#PCDATA)>
<!ELEMENT imagen         (#PCDATA)>
<!ELEMENT garantia_anios (#PCDATA)>

<!-- Precio con atributo de moneda -->
<!ELEMENT precio (#PCDATA)>
<!ATTLIST precio
  moneda CDATA #REQUIRED
>

<!-- Especificaciones técnicas - todos opcionales porque varían por producto -->
<!ELEMENT especificaciones (
  procesador?   |
  ram?          |
  almacenamiento? |
  pantalla?     |
  bateria?      |
  licencias?    |
  actualizaciones? |
  soporte?      |
  plataforma?   |
  tipo_licencia? |
  capacidad?    |
  bahias?       |
  raid?         |
  conectividad? |
  consumo?      |
  visitas?      |
  soporte_remoto? |
  tiempo_respuesta? |
  limpieza?     |
  estandar?     |
  cobertura?    |
  seguridad?    |
  puntos_acceso? |
  gestion?      |
  resolucion?   |
  panel?        |
  tasa_refresco? |
  conectores?   |
  tiempo_respuesta_ms? |
  aplicaciones? |
  almacenamiento_nube? |
  usuarios?     |
  conexion?     |
  dpi?          |
  layout?       |
  color?        |
  interfaz?     |
  velocidad_lectura? |
  velocidad_escritura? |
  alimentacion? |
  puertos?      |
  velocidad?    |
  vlan?         |
  montaje?
)*>

<!-- Todos los campos de especificaciones contienen texto -->
<!ELEMENT procesador        (#PCDATA)>
<!ELEMENT ram               (#PCDATA)>
<!ELEMENT almacenamiento    (#PCDATA)>
<!ELEMENT pantalla          (#PCDATA)>
<!ELEMENT bateria           (#PCDATA)>
<!ELEMENT licencias         (#PCDATA)>

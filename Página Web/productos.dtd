<!ELEMENT soporte           (#PCDATA)>
<!ELEMENT plataforma        (#PCDATA)>
<!ELEMENT tipo_licencia     (#PCDATA)>
<!ELEMENT capacidad         (#PCDATA)>
<!ELEMENT bahias            (#PCDATA)>
<!ELEMENT raid              (#PCDATA)>
<!ELEMENT conectividad      (#PCDATA)>
<!ELEMENT consumo           (#PCDATA)>
<!ELEMENT visitas           (#PCDATA)>
<!ELEMENT soporte_remoto    (#PCDATA)>
<!ELEMENT tiempo_respuesta  (#PCDATA)>
<!ELEMENT limpieza          (#PCDATA)>
<!ELEMENT estandar          (#PCDATA)>
<!ELEMENT cobertura         (#PCDATA)>
<!ELEMENT seguridad         (#PCDATA)>
<!ELEMENT puntos_acceso     (#PCDATA)>
<!ELEMENT gestion           (#PCDATA)>
<!ELEMENT resolucion        (#PCDATA)>
<!ELEMENT panel             (#PCDATA)>
<!ELEMENT tasa_refresco     (#PCDATA)>
<!ELEMENT conectores        (#PCDATA)>
<!ELEMENT aplicaciones      (#PCDATA)>
<!ELEMENT almacenamiento_nube (#PCDATA)>
<!ELEMENT usuarios          (#PCDATA)>
<!ELEMENT conexion          (#PCDATA)>
<!ELEMENT dpi               (#PCDATA)>
<!ELEMENT layout            (#PCDATA)>
<!ELEMENT color             (#PCDATA)>
<!ELEMENT interfaz          (#PCDATA)>
<!ELEMENT velocidad_lectura (#PCDATA)>
<!ELEMENT velocidad_escritura (#PCDATA)>
<!ELEMENT alimentacion      (#PCDATA)>
